# AI Platform 环境变量配置
# 复制此文件为 .env 并填入实际值
# Node.js 20+ 支持: node --env-file .env dist/index.js

# LLM API 配置（必填）
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1

# 管理员密码（可选，默认使用 config.yaml 中 admin.password）
ADMIN_PASSWORD=admin123

# 日志级别: debug | info | warn | error
LOG_LEVEL=info
